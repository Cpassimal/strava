{
  "manifest_version": 3,
  "name": "Strava Performance Dashboard",
  "version": "1.0.0",
  "description": "Dashboard d'analyse de performance Strava",
  "permissions": [
    "identity",
    "storage",
    "unlimitedStorage",
    "cookies",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://www.strava.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Strava Dashboard"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
